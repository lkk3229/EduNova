# EduNova Backend Environment Variables (Local Dev)

# Server Configuration
PORT=5000
NODE_ENV=development

# Logging Configuration
LOG_LEVEL=debug

# Performance & Monitoring Configuration (Phase 3)
ENABLE_RESPONSE_CACHE=true
CACHE_TTL_SECONDS=120
PERF_SLOW_REQUEST_MS=1000
PERF_MAX_ROUTE_SAMPLES=200

# Frontend Configuration
FRONTEND_URL=http://localhost:3000

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/edunova

# JWT Configuration
JWT_SECRET=dev-local-jwt-secret-32-characters-minimum-ok
JWT_EXPIRE=7d

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Email Configuration (dev-safe placeholder values)
EMAIL_SERVICE=gmail
EMAIL_USER=dev.edunova@example.com
EMAIL_PASS=dev-app-password-placeholder

# Payment Gateway Configuration (Phase 2)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# File Upload Configuration (Phase 2)
UPLOAD_PATH=./uploads

# Optional external providers
# SENTRY_DSN=
# AWS_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=
