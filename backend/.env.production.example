# EduNova Backend Production Environment Variables
# Copy to .env in production and replace placeholders with real secrets.

# Server
PORT=5000
NODE_ENV=production
DB_MODE=mongo
LOG_LEVEL=info
AUDIT_LOGGING_ENABLED=true

# Frontend/App URLs
FRONTEND_URL=https://app.edunova.example
CORS_ORIGIN=https://app.edunova.example

# Database
# MongoDB is required in production while API routes remain Mongoose-based.
MONGODB_URI=mongodb+srv://db_user:db_password@cluster0.example.mongodb.net/edunova?retryWrites=true&w=majority

# Supabase is optional in DB_MODE=mongo and required in DB_MODE=supabase or DB_MODE=hybrid.
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=replace-with-supabase-anon-key-from-api-settings
SUPABASE_SERVICE_KEY=replace-with-supabase-service-role-key-from-api-settings

# Auth
JWT_SECRET=replace-with-64-plus-char-random-secret
JWT_EXPIRE=7d

# Email (required by backend validation)
EMAIL_SERVICE=gmail
EMAIL_USER=notifications@edunova.example
EMAIL_PASS=replace-with-app-password-or-provider-secret

# Payments (set live keys for real checkout)
RAZORPAY_KEY_ID=rzp_live_replace_me
RAZORPAY_KEY_SECRET=replace-with-live-secret

# Uploads
UPLOAD_PATH=./uploads

# Performance & Monitoring (Phase 3)
ENABLE_RESPONSE_CACHE=true
CACHE_TTL_SECONDS=120
PERF_SLOW_REQUEST_MS=1000
PERF_MAX_ROUTE_SAMPLES=200

# Optional Integrations
SENTRY_DSN=
# AWS_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=
