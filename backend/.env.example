SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im5pZ3VlbXpqeHB6emNvdWhodmVwIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3ODQ4MTUyOSwiZXhwIjoyMDk0MDU3NTI5fQ.yTdTgJyTEI2OU1vW_iIY2wZ7cYioXnek9rOHUe4MQMo

# MongoDB (Optional fallback)
# MONGODB_URI=mongodb://localhost:27017/edunova

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-minimum-32-characters
JWT_EXPIRE=7d

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Email Configuration (Gmail example)
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-specific-password

# Payment Gateway Configuration (Phase 2)
# Leave blank to use manual/dev payment fallback mode.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# File Upload Configuration (Phase 2)
# Relative or absolute upload path
UPLOAD_PATH=./uploads

# Optional external providers
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_S3_BUCKET=your-bucket-name
