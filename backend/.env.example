# EduNova Backend Environment Variables
# Copy this file to .env and update with your values

# Server Configuration
PORT=5000
NODE_ENV=development
DB_MODE=mongo

# Logging Configuration
# Levels: error, warn, info, http, debug
LOG_LEVEL=debug
AUDIT_LOGGING_ENABLED=true

# Performance & Monitoring Configuration (Phase 3)
ENABLE_RESPONSE_CACHE=true
CACHE_TTL_SECONDS=120
PERF_SLOW_REQUEST_MS=1000
PERF_MAX_ROUTE_SAMPLES=200

# Frontend Configuration
FRONTEND_URL=http://localhost:3000

# Database Configuration
# MongoDB (Required when DB_MODE=mongo or DB_MODE=hybrid)
MONGODB_URI=mongodb://localhost:27017/edunova

# Supabase (Optional, required when DB_MODE=supabase or DB_MODE=hybrid)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=replace-with-supabase-anon-key
SUPABASE_SERVICE_KEY=replace-with-supabase-service-role-key

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-minimum-32-characters
JWT_EXPIRE=7d

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Email Configuration (Gmail example)
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-specific-password

# Payment Gateway Configuration (Phase 2)
# Leave blank to use manual/dev payment fallback mode.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# File Upload Configuration (Phase 2)
# Relative or absolute upload path
UPLOAD_PATH=./uploads

# Optional external providers
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_S3_BUCKET=your-bucket-name
